<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="category.product.addto.wishlist" remove="true"/>
        <referenceBlock name="category.product.list.additional.wishlist_addto" remove="true"/>
        <referenceBlock name="category.product.addto.compare" remove="true"/>
        <!-- Hyva Alpine JS glue — these emit addToWishlist() / addToCompare()
             functions globally. Removing removes the leftover JS even though
             the visible buttons are already gone. -->
        <referenceBlock name="category.products.list.js.wishlist" remove="true"/>
        <referenceBlock name="category.products.list.js.compare" remove="true"/>
    </body>
</page>
