<?xml version="1.0"?>
<!--
/**
 * Panth Disable Wishlist & Compare — ACL
 * - Registers the menu entry under Panth_Core::panth_extensions (declared by Panth_Core)
 * - Registers the system-config section resource so the ACL role editor lists it
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <!-- Link under Panth Infotech parent (declared by Panth_Core) -->
                <resource id="Panth_Core::panth_extensions">
                    <resource id="Panth_DisableWishlistCompare::config"
                              title="Disable Wishlist &amp; Compare"
                              sortOrder="50"/>
                </resource>

                <!-- System Configuration Access -->
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_DisableWishlistCompare::config"
                                      title="Panth Disable Wishlist &amp; Compare Configuration"
                                      sortOrder="500"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
